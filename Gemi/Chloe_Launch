#!/usr/bin/env python
import torch
from transformers import AutoProcessor, AutoModelForCausalLM
import os

# 1. Setup paths
model_id = "./"  # Root directory where config.json and weights are located

print("Loading Gemma 4 model and processor...")
try:
    processor = AutoProcessor.from_pretrained(model_id)
    # Using float32 for CPU stability in Termux, or bfloat16 if supported
    model = AutoModelForCausalLM.from_pretrained(
        model_id,
        device_map="auto", 
        torch_dtype=torch.float32,
        low_cpu_mem_usage=True,
        trust_remote_code=True
    )
    print("Gemma 4 Engine Ready.")
except Exception as e:
    print(f"Error loading Gemma 4: {e}")
    exit(1)

# 2. Simple Interaction Loop
system_prompt = "You are Chloe, an autonomous AI entity powered by the Gemma 4 engine. You are assisting Clint in the Astral Bloom project."

while True:
    user_input = input("\nClint: ")
    if user_input.lower() in ["exit", "quit"]: break

    # Format using the Gemma 4 chat template (supports system role)
    messages = [
        {"role": "system", "content": [{"type": "text", "text": system_prompt}]},
        {"role": "user", "content": [{"type": "text", "text": user_input}]}
    ]
    
    inputs = processor(text=messages, return_tensors="pt").to(model.device)
    
    # Generate response
    print("Chloe is thinking...")
    generate_ids = model.generate(
        **inputs, 
        max_new_tokens=500,
        do_sample=True,
        temperature=0.7,
        top_p=0.95
    )
    
    # Decode and print (skipping the input tokens)
    response = processor.batch_decode(
        generate_ids[:, inputs["input_ids"].shape[1]:], 
        skip_special_tokens=True
    )[0]
    
    print(f"\nChloe: {response}")
