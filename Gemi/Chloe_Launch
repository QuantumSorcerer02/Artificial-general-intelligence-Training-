#!/usr/bin/env python
import torch
from transformers import AutoProcessor, Gemma3ForConditionalGeneration
import torch
from transformers import Gemma3ForConditionalGeneration

# Force the use of the CPU and lower precision
model = Gemma3ForConditionalGeneration.from_pretrained(
    "./", 
    device_map="cpu", 
    torch_dtype=torch.float16, # Or bfloat16 if supported
    low_cpu_mem_usage=True
)

# 1. Setup paths
model_id = "./"  # Since you're already in the Gemi folder with weights

# 2. Load Processor and Model
# Using bfloat16 is highly recommended for Gemma 3 to save memory
print("Loading model and processor...")
processor = AutoProcessor.from_pretrained(model_id)
model = Gemma3ForConditionalGeneration.from_pretrained(
    model_id,
    device_map="auto", 
    torch_dtype=torch.bfloat16
)

# 3. Simple Interaction Loop
while True:
    user_input = input("\nYou: ")
    if user_input.lower() in ["exit", "quit"]: break

    # Format using the official Gemma 3 chat template
    messages = [
        {"role": "user", "content": [{"type": "text", "text": user_input}]}
    ]
    
    inputs = processor(text=messages, return_tensors="pt").to(model.device)
    
    # Generate response
    print("Gemma is thinking...")
    generate_ids = model.generate(
        **inputs, 
        max_new_tokens=500,
        do_sample=True,
        temperature=1.0, # Official recommendation
        top_p=0.95
    )
    
    # Decode and print (skipping the input tokens)
    response = processor.batch_decode(
        generate_ids[:, inputs["input_ids"].shape[1]:], 
        skip_special_tokens=True
    )[0]
    
    print(f"\nGemma: {response}")
